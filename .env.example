# Copy to .env (which is gitignored) and fill in real values.
# Never commit .env. Never paste real keys into pull requests or issues.

# --- EIA Open Data API ---
# Register free at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# --- ERCOT Public API (apiexplorer.ercot.com) ---
# Register free at https://apiexplorer.ercot.com/
# OAuth2 flow needs your ERCOT account username+password AND the subscription key
# for the "Public API" product (not the ESR API product).
ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=
ERCOT_API_SUBSCRIPTION_KEY=

# --- Copernicus CDS (ERA5) — optional, phase-3 calibration only ---
# Register at https://cds.climate.copernicus.eu/
# Leave blank unless you're adding ERA5 actuals.
CDSAPI_URL=
CDSAPI_KEY=
